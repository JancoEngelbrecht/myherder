DB_PATH=
# REQUIRED: Set to a random string of at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
NODE_ENV=
PORT=

# REQUIRED in production: comma-separated list of allowed CORS origins.
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# Production MySQL (used when NODE_ENV=production)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── JWT token lifetimes (optional) ─────────────────────────────
# Defaults: password=24h, pin=7d. Accepts any `jsonwebtoken` duration string.
JWT_EXPIRY_PASSWORD=24h
JWT_EXPIRY_PIN=7d

# ── Login rate limit (optional) ────────────────────────────────
# Defaults: 10 attempts per 15-minute window per IP.
LOGIN_RATE_LIMIT_WINDOW=900000
LOGIN_RATE_LIMIT_MAX=10

# ── Account lockout on failed attempts (optional) ──────────────
# Defaults: lock account for 15min after 5 failed attempts.
LOCKOUT_DURATION=900000
LOCKOUT_THRESHOLD=5

# ── Super-admin bootstrap (REQUIRED for production seeder) ─────
# The production super-admin seed (server/seeds/production/001_super_admin.js)
# reads these. Without them the seeder cannot create the initial super-admin.
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=

# ── Dev-only 2FA bypass (NEVER set in production) ──────────────
# If true, super-admin login skips TOTP. Refuses to start in production.
# SKIP_2FA=true
