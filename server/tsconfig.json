{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "moduleDetection": "force",
    "strict": false,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/types/*"]
    },
    "outDir": "../dist",
    "rootDir": ".",
    "declaration": false,
    "types": ["jest", "node"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "migrations", "seeds", "dist", "tests/**/*.ts"]
}
