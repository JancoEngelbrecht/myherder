{
  "name": "myherder",
  "version": "1.0.0",
  "description": "Dairy farm management application",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "wait-on tcp:3000 && cd client && npm run dev",
    "build": "npm run build:server && cd client && npm run build",
    "build:server": "tsc -p server/tsconfig.json",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,json,css,md}\"",
    "typecheck": "tsc -p server/tsconfig.json --noEmit",
    "knip": "knip",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.20.0",
    "otpauth": "^9.5.0",
    "pdfkit": "^0.18.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "knip": "^5.84.1",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "*.{js,ts,vue,css,json,md,yaml,yml}": "prettier --write",
    "*.{js,ts,vue}": "eslint --fix"
  }
}
