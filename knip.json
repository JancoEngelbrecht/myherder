{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["server/app.js"],
      "project": ["server/**/*.js", "!server/tests/**"]
    },
    "client": {
      "project": ["src/**/*.{js,vue}"]
    }
  },
  "ignore": ["server/config/env.js"],
  "ignoreExportsUsedInFile": true
}
